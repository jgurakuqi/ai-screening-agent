# --- LLM Provider: "azure" or "openrouter" ---
LLM_PROVIDER=azure

# --- Azure OpenAI (AI Foundry) ---
AZURE_OPENAI_API_KEY=your_azure_key_here
AZURE_OPENAI_ENDPOINT=https://your-deployment.cognitiveservices.azure.com
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_PRIMARY_MODEL=gpt-5.4-mini
AZURE_FALLBACK_MODEL=

# --- OpenRouter (kept as fallback) ---
OPENROUTER_API_KEY=your_key_here
PRIMARY_MODEL=meta-llama/llama-3.1-8b-instruct:free
FALLBACK_MODEL=google/gemma-2-9b-it:free
FALLBACK_MODEL_2=mistralai/mistral-7b-instruct:free
# Comma-separated additional free-tier models for deeper fallback (22 models total by default)
# EXTRA_FREE_MODELS=model1:free,model2:free

# --- Conversation settings ---
DB_PATH=data/conversations.db
REENGAGEMENT_TIMEOUT_MINUTES=10
REENGAGEMENT_MAX_ATTEMPTS=3
CONVERSATION_ABANDON_HOURS=3
MAX_CLARIFICATION_ATTEMPTS=3
ENABLE_SCHEDULER=true
DATA_RETENTION_DAYS=30
MAX_OFFENSIVE_STRIKES=2

# --- LLM resilience (retry / rate-limit backoff) ---
LLM_MAX_RETRIES_PER_MODEL=3
LLM_RETRY_BASE_DELAY_SECONDS=2.0
LLM_RATE_LIMIT_BASE_DELAY_SECONDS=12.0
LLM_RATE_LIMIT_MAX_WAIT_SECONDS=60.0
LLM_PASS_BASE_DELAY_SECONDS=15.0
LLM_PASS_MAX_WAIT_SECONDS=300.0
LLM_MAX_FULL_PASSES=0
LLM_JITTER_FRACTION=0.3
LLM_EMPTY_CONTENT_COOLDOWN_SECONDS=600

# --- TTS configuration ---
TTS_PROVIDER=edge-tts
TTS_EDGE_VOICE_ES=es-MX-DaliaNeural
TTS_EDGE_VOICE_EN=en-US-JennyNeural

# --- STT configuration ---
STT_MODEL_SIZE=small
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_AUTO_LANGUAGE_THRESHOLD=0.65
STT_VAD_MIN_SILENCE_MS=500

# --- Frontend ---
FRONTEND_MESSAGE_TIMEOUT_SECONDS=90
